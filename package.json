{
  "name": "kemparaj-s-portfolio",
  "version": "1.0.0",
  "description": "Premium Full-Stack Portfolio with Analytics & Admin Management System",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:backend": "nodemon src/server.js",
    "dev:frontend": "live-server public --port=3000 --open=index.html",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "apply-schema": "node scripts/applySchema.js",
    "add-admin": "node scripts/addAdmin.js"
  },
  "keywords": [
    "portfolio",
    "full-stack",
    "express",
    "mysql",
    "analytics",
    "socket.io"
  ],
  "author": "Kemparaj S",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.7",
    "nodemailer": "^6.9.13",
    "pdfkit": "^0.13.0",
    "socket.io": "^4.7.5",
    "useragent": "^2.3.0",
    "winston": "^3.9.0",
    "xss-clean": "^0.1.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "live-server": "^1.2.2",
    "nodemon": "^3.1.0"
  }
}
